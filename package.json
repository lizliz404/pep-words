{
  "name": "pep_english_vocab_learner",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "vite preview --host --port 3000",
    "check": "tsc --noEmit",
    "words:build": "python3 scripts/merge-clean-words.py",
    "words:tasks": "python3 scripts/build-enrichment-tasks.py",
    "words:enrich": "python3 scripts/build-enrichment.py",
    "words:enrich-dict": "python3 scripts/enrich-from-dictionaries.py",
    "words:validate": "python3 scripts/validate-word-data.py",
    "words:validate-enrichment": "python3 scripts/validate-enrichment.py"
  },
  "dependencies": {
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.3",
    "@types/react": "^19.2.1",
    "@types/react-dom": "^19.2.1",
    "@vitejs/plugin-react": "^5.0.4",
    "tailwindcss": "^4.1.14",
    "typescript": "5.6.3",
    "vite": "^7.1.7"
  }
}
